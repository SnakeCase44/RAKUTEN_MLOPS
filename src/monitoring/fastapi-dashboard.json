{
  "uid": "fastapi-metrics",
  "title": "FastAPI Monitoring",
  "tags": ["fastapi", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 5,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "API Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"fastapi\"}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "UP" },
                "0": { "text": "DOWN" }
              }
            }
          ]
        }
      }
    },
    {
      "type": "table",
      "title": "Requêtes HTTP (endpoint, méthode)",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "http_requests_total",
          "refId": "B",
          "format": "table"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "handler": "Endpoint",
              "method": "Méthode",
              "Value": "Total requêtes"
            },
            "excludeByName": { "instance": true, "job": true }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Durée moyenne par route (s)",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "http_request_duration_seconds_sum / http_request_duration_seconds_count",
          "legendFormat": "{{handler}} ({{method}})",
          "refId": "C"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "type": "table",
      "title": "Requêtes par endpoint",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (handler) (http_requests_total)",
          "refId": "D",
          "format": "table"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "decimals": 0 }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "handler": "Endpoint",
              "Value": "Nombre de requêtes (5min)"
            }
          }
        }
      ]
    }
  ]
}