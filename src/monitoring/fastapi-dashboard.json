{
  "id": null,
  "uid": "fastapi-metrics",
  "title": "FastAPI Monitoring",
  "tags": ["fastapi", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "panels": [
    {
      "type": "stat",
      "title": "API Health (up)",
      "targets": [
        {
          "expr": "up{job=\"fastapi\"}",
          "refId": "A",
          "interval": "10s"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 4}
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "targets": [
        {
          "expr": "http_requests_total",
          "refId": "B",
          "interval": "10s"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 4}
    },
    {
      "type": "graph",
      "title": "Request Duration (seconds)",
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])",
          "refId": "C",
          "interval": "10s"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8}
    },
    {
      "type": "table",
      "title": "Requests by Path",
      "targets": [
        {
          "expr": "sum by (path) (rate(http_requests_total[1m]))",
          "refId": "D",
          "interval": "10s"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8}
    }
  ]
}
