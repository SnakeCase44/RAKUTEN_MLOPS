{
  "uid": "mlflow-multiclass",
  "title": "MLflow Dashboard",
  "tags": ["mlflow", "ml"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 4,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Progression des Epochs",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "mlflow_run_metric{name=\"epoch\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Learning Rate (AdamW)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "mlflow_run_metric{name=\"lr-AdamW\"}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "table",
      "title": "F1 Score par classe (Dernier run)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "mlflow_run_metric{name=~\"test_.*_f1_score\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Classe F1",
              "Value": "Score",
              "run_id": "Run ID"
            },
            "excludeByName": {
              "Time": true,
              "experiment_id": true,
              "job": true,
              "instance": true
            }
          }
        }
      ]
    },
    {
      "type": "stat",
      "title": "F1 Macro / Micro / Weighted",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 5 },
      "targets": [
        {
          "expr": "max(mlflow_run_metric{name=\"test_macro_f1\"})",
          "refId": "A",
          "legendFormat": "Macro F1"
        },
        {
          "expr": "max(mlflow_run_metric{name=\"test_micro_f1\"})",
          "refId": "B",
          "legendFormat": "Micro F1"
        },
        {
          "expr": "max(mlflow_run_metric{name=\"test_weighted_f1\"})",
          "refId": "C",
          "legendFormat": "Weighted F1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "displayMode": "basic"
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "table",
      "title": "Métriques globales par run",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "mlflow_run_metric{name=~\"^test_(accuracy|macro_f1|weighted_f1|micro_f1)$\"}",
          "format": "table",
          "refId": "F",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true,
              "experiment_id": true
            },
            "renameByName": {
              "run_id": "Run ID",
              "name": "Metric",
              "Value": "Score"
            }
          }
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Score" },
            "properties": [
              { "id": "unit", "value": "percentunit" }
            ]
          }
        ]
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    },
    {
      "type": "timeseries",
      "title": "Top 10 Classes - F1 Score",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "topk(10, mlflow_run_metric{name=~\"test_.*_f1_score\"})",
          "refId": "G",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "datasource": { "type": "prometheus", "uid": "prometheus" }
    }
  ]
}