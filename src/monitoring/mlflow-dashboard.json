{
  "uid": "mlflow-monitor",
  "title": "MLflow Metrics",
  "tags": ["mlflow", "ml"],
  "timezone": "browser",
  "schemaVersion": 27,
  "version": 5,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Epoch Progress",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "mlflow_run_metric{name=\"epoch\"}",
          "refId": "A",
          "legendFormat": "Epoch - {{experiment_id}}/{{run_id}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries",
      "title": "Learning Rate & Adam Weight",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "mlflow_run_metric{name=\"lr-AdamW\"}",
          "refId": "B",
          "legendFormat": "Learning Rate AdamW - {{experiment_id}}/{{run_id}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "type": "timeseries",
      "title": "F1 Scores (All Tests)",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "mlflow_run_metric{name=~\".*f1.*\"}",
          "refId": "C",
          "legendFormat": "{{name}} - {{experiment_id}}/{{run_id}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "type": "timeseries",
      "title": "Precision Scores (All Tests)",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "mlflow_run_metric{name=~\".*precision.*\"}",
          "refId": "D",
          "legendFormat": "{{name}} - {{experiment_id}}/{{run_id}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "type": "timeseries",
      "title": "Recall Scores (All Tests)",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "mlflow_run_metric{name=~\".*recall.*\"}",
          "refId": "E",
          "legendFormat": "{{name}} - {{experiment_id}}/{{run_id}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "type": "stat",
      "title": "Latest Test Results (Current Run Only)",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "max(mlflow_run_metric{name=\"test_60_f1\"})",
          "refId": "F",
          "legendFormat": "Test 60 F1"
        },
        {
          "expr": "max(mlflow_run_metric{name=\"test_60_precision\"})",
          "refId": "G",
          "legendFormat": "Test 60 Precision"
        },
        {
          "expr": "max(mlflow_run_metric{name=\"test_60_recall\"})",
          "refId": "H",
          "legendFormat": "Test 60 Recall"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}}
    },
    {
      "type": "table",
      "title": "All Runs Comparison",
      "gridPos": {"x": 0, "y": 18, "w": 24, "h": 6},
      "targets": [
        {
          "expr": "mlflow_run_metric{name=~\"test_60_(f1|precision|recall)\"}",
          "format": "table",
          "refId": "I",
          "instant": true
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [{"id": "unit", "value": "percentunit"}]
          }
        ]
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true,
              "experiment_id": true
            },
            "indexByName": {},
            "renameByName": {
              "run_id": "Run ID",
              "name": "Metric",
              "Value": "Score"
            }
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "Current Run Parameters",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "mlflow_run_param",
          "format": "table",
          "refId": "J",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "name": {
                "aggregations": [],
                "operation": "groupby"
              },
              "Value": {
                "aggregations": ["lastNotNull"],
                "operation": "aggregate"
              }
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "All Metrics Overview",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "topk(5, mlflow_run_metric)",
          "refId": "L",
          "legendFormat": "{{name}} - {{run_id|substr 0 8}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ]
}
